{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "respectGitignore": true,
  "permissions": {
    "deny": [
      "Read(./node_modules/**)",
      "Read(./dist/**)",
      "Read(./build/**)",
      "Read(./coverage/**)",
      "Read(./.next/**)",
      "Read(./out/**)",
      "Read(./tmp/**)",
      "Read(./.cache/**)",
      "Read(./vendor/**)",
      "Read(./**/*.map)",
      "Read(./**/*.min.js)",
      "Read(./**/*.bundle.js)",
      "Read(./src/snipcom_app/**/__pycache__/**)"
    ]
  }
}
